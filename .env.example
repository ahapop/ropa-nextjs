# --- Database (Vercel Postgres / Neon) ---
# Set automatically by Vercel when a Postgres database is linked to the project.
# For local dev, copy this file to .env.local and fill in the real value.
POSTGRES_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Auth ---
# Secret used to sign session cookies. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: set this in the Vercel project Environment Variables for production.
AUTH_SECRET=replace-with-a-long-random-string

# First run only: create tables + seed the admin account with
#   node scripts/init-db.mjs
